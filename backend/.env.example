DATABASE_URL="postgresql://user:password@localhost:5432/pilotjobs"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development

# Firebase Admin SDK
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Scraper config
SCRAPE_INTERVAL_HOURS=6
# Identifies us in the User-Agent on every scraper request: PilotJobsIngest/1.0 (+contact: <CONTACT_EMAIL>)
# Set this to a real address so source sites can reach out rather than silently block us.
CONTACT_EMAIL=your-email@example.com

# Uploadcare (photo storage for CV Builder)
UPLOADCARE_PUBLIC_KEY=your_uploadcare_public_key
UPLOADCARE_SECRET_KEY=your_uploadcare_secret_key

# ── Job scraping sources ─────────────────────────────────────────────
# USAJobs.gov (free — register at developer.usajobs.gov)
USAJOBS_API_KEY=your_usajobs_api_key
USAJOBS_USER_AGENT=your-registered-email@example.com

# Adzuna — Europe job volume (free — register at developer.adzuna.com)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
# Optional overrides:
# ADZUNA_COUNTRIES=gb,fr,de,it,es,nl,pl,at
# ADZUNA_MAX_PAGES=2

# Jooble — North Africa job volume (free — register at jooble.org/api/about)
JOOBLE_API_KEY=your_jooble_api_key
# Optional overrides:
# JOOBLE_LOCATIONS=Egypt,Morocco,Tunisia,Algeria
# JOOBLE_MAX_PAGES=3

# Scrape frequency (hours between runs; default 6)
SCRAPE_INTERVAL_HOURS=6

# DeepL translation (free tier: 500k chars/month) — register at deepl.com/pro-api
# Required for showing non-English job listings in English.
DEEPL_API_KEY=
# Max jobs translated per sweep (default 80)
TRANSLATE_BATCH=80
